    "job.name": "__JOB_NAME__ (e.g. AUTO_FLB_NJM-XXXXX)",
    "objects[0].sourceVid": "__SOURCE_BACKUP_OBJECT_VID__ (an EXISTING BACKUP_OBJECT-<id> — from BackupManagement.getBackupObjects, NOT a discovery VID like PM-2/PM-3)",
    "objects[0].targetName": "__SOURCE_NAME__ (the source backup object's own 'name' field)",
    "objects[0].targetStorageVid": "__TARGET_REPO_VID__ (BACKUP_REPOSITORY-<id> — must differ from the source object's own repositoryVid)"
