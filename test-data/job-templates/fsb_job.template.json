    "objects[0].targetName": "__SOURCE_NAME__ (CIFS-FileTypeSamples)",
    "objects[0].targetStorageVid": "__TARGET_REPO_VID__ (BACKUP_REPOSITORY-1 Onboard | -2 Cloudian | -3 Backblaze | -4 Wasabi | -5 Ceph | -6 HPE, all on nbr-5)",
    "objects[0].mappings[]": "[] for the whole share, OR one {type:NORMAL, sourceIdentifier:<file path>, sourceIdentifierType:FILE, ...nulls} per selected file (MappingBuilder) — FSB has no FOLDER scope"
