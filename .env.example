# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# Loaded by browser/pom/base/config.py's load_app_config() for every test/check/script that
# talks to the Director UI. See that module's docstring for the full typed, multi-environment
# configuration system (also: docs/configuration.md).

# nbr-84 — File-Level Backup appliance (FLB test suites)
NBR_FLB_URL=https://10.10.16.84:4443
NBR_FLB_USER=test1
NBR_FLB_PASS=

# nbr-5 — File Share Backup appliance (FSB test suites)
NBR_FSB_URL=https://10.10.15.5:4443
NBR_FSB_USER=test1
NBR_FSB_PASS=

# win-fs3 (10.10.15.3) — the documented FLR CIFS/NFS export target (see test-data/environment.md)
# Auto-loaded by config.py's AppConfig.share("winfs3") for any test that recovers to a CIFS share
# via the FLR wizard's 'Recover to custom location' option.
WINFS3_USER=Administrator
WINFS3_PASS=

# ---------------------------------------------------------------------------------------------
# Multiple environments (NBR_ENV) — see docs/configuration.md for the full writeup.
#
# This file (.env) is the "local" environment's config — this project's only real target today,
# the lab appliances above. NBR_ENV selects among 5 named environments: local (default) / dev /
# qa / staging / production. Selecting a non-local one that has no matching file below is a hard
# error (ConfigError), not a silent fallback to these local values and not a fabricated fake one.
#
# To provision a real dev/qa/staging/production appliance later: create .env.<environment>
# (gitignored, same as .env) with just the keys that differ for that environment — e.g. a file
# named ".env.qa" containing only NBR_FLB_URL=... overrides just that key, while
# NBR_FLB_USER/NBR_FLB_PASS still fall back to this base .env if unset there. Then run with:
#   NBR_ENV=qa pytest tests/e2e -v
#
# No .env.dev / .env.qa / .env.staging / .env.production ships with this repo — none of those
# appliances exist yet. Do not create one with placeholder/fake values "to complete the set".
