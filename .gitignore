# Secrets — never commit real credentials. Copy the .example.json files and fill them in locally.
browser/config/ui_config.json
browser/config/ui_config_fsb.json

# Secrets — copy .env.example to .env and fill in real values locally (never commit .env).
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Generated Allure output — every pytest run appends fresh raw results here (--alluredir), and
# `allure generate`/`allure serve` renders them on demand. Committing the raw results or the
# rendered HTML/JS bundle would just churn the repo on every run.
results/allure-results/
results/allure-report/
results/test-results/
results/junit.xml
# Local Allure trend history (allurerc.json's historyPath) — accumulates across every local
# `allure generate` run on this machine specifically; committing it would mix every dev's local
# run history into one file. See docs/ci-secrets.md's e2e-appliance job for why CI-side trend
# persistence (caching this file across workflow runs) isn't wired up yet — no runner exists to
# verify it against.
results/allure-history.jsonl

# Claude-in-Chrome MCP tool session state (console logs, page snapshots) — not project content.
.playwright-mcp/

# Playwright traces (opt-in, for replaying a specific failure) and raw DOM/screenshot dumps
# from ad-hoc live-calibration/exploration sessions — ephemeral debugging output, not the
# permanent per-TC evidence (that's results/screenshots/<TC>/, which IS tracked).
results/traces/
results/dom_dumps/

# OS junk
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/

# Local Claude Code runtime state (not project source)
.claude/
